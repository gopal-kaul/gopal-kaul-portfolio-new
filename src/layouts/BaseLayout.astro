---
import '../styles/global.css';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import { ClientRouter } from 'astro:transitions';

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  type?: 'website' | 'article';
  publishedTime?: string;
  modifiedTime?: string;
  tags?: string[];
}

const {
  title = 'Gopal Kaul — Software Developer',
  description = 'Gopal Kaul is a software developer building fast web interfaces and pragmatic backend flows with React, TypeScript, Spring Boot, and Linux-first tooling.',
  ogImage = '/og-image.svg',
  type = 'website',
  publishedTime,
  modifiedTime,
  tags = [],
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site || 'https://gopal-kaul.is-a.dev');
const absoluteOgImage = new URL(ogImage, canonicalURL.origin);
const gaId = import.meta.env.PUBLIC_GA_MEASUREMENT_ID;
const siteName = 'Gopal Kaul';
const twitterHandle = '@kaulmegops';
const googleSiteVerification = 'zFvF2YGk_82EaBgAUD3l8bj1l-qiaSUfXi811joKEw8';
const keywords = [
  'Gopal Kaul',
  'Software Developer',
  'Full Stack Developer',
  'Web Developer',
  'React Developer',
  'Node.js',
  'TypeScript',
  'Spring Boot',
  'Astro',
  'Hyderabad',
  ...tags,
].join(', ');
const personJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: 'Gopal Kaul',
  alternateName: 'BL4Z3',
  url: canonicalURL.origin,
  jobTitle: 'Software Developer',
  worksFor: { '@type': 'Organization', name: 'Fanatics' },
  address: { '@type': 'PostalAddress', addressLocality: 'Hyderabad', addressCountry: 'IN' },
  sameAs: [
    'https://github.com/gopal-kaul',
    'https://linkedin.com/in/gopal-kaul',
    'https://instagram.com/kaulmegops',
    'https://twitter.com/kaulmegops',
  ],
  knowsAbout: ['React', 'TypeScript', 'Spring Boot', 'Astro', 'Linux', 'Neovim'],
};
const websiteJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: `${siteName} - Software Developer`,
  alternateName: siteName,
  url: canonicalURL.origin,
  description,
  publisher: {
    '@type': 'Person',
    name: siteName,
  },
};
const articleJsonLd = type === 'article' ? {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: title.replace(' — Gopal Kaul', ''),
  description,
  image: absoluteOgImage.href,
  url: canonicalURL.href,
  datePublished: publishedTime,
  dateModified: modifiedTime || publishedTime,
  author: personJsonLd,
  keywords: tags.join(', '),
} : null;
---

<!DOCTYPE html>
<html lang="en" class="dark">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="generator" content={Astro.generator} />

    <!-- SEO -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="author" content="Gopal Kaul" />
    <meta name="keywords" content={keywords} />
    <meta name="robots" content="index, follow, max-snippet:-1, max-image-preview:large, max-video-preview:-1" />
    <meta name="google-site-verification" content={googleSiteVerification} />
    <meta name="color-scheme" content="dark light" />
    <meta name="theme-color" content="#0a0a0b" media="(prefers-color-scheme: dark)" />
    <meta name="theme-color" content="#fafaf9" media="(prefers-color-scheme: light)" />
    <link rel="canonical" href={canonicalURL.href} />
    <link rel="alternate" href={canonicalURL.href} hreflang="en" />

    <!-- Open Graph -->
    <meta property="og:type" content={type} />
    <meta property="og:site_name" content={siteName} />
    <meta property="og:locale" content="en_IN" />
    <meta property="og:url" content={canonicalURL.href} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={absoluteOgImage.href} />
    <meta property="og:image:type" content={ogImage.endsWith('.svg') ? 'image/svg+xml' : 'image/webp'} />
    <meta property="og:image:alt" content={`${title} social preview`} />
    {publishedTime && <meta property="article:published_time" content={publishedTime} />}
    {modifiedTime && <meta property="article:modified_time" content={modifiedTime} />}
    {tags.map((tag) => <meta property="article:tag" content={tag} />)}

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content={twitterHandle} />
    <meta name="twitter:creator" content={twitterHandle} />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={absoluteOgImage.href} />
    <meta name="twitter:image:alt" content={`${title} social preview`} />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />

    <script type="application/ld+json" set:html={JSON.stringify(personJsonLd)} />
    <script type="application/ld+json" set:html={JSON.stringify(websiteJsonLd)} />
    {articleJsonLd && <script type="application/ld+json" set:html={JSON.stringify(articleJsonLd)} />}

    <!-- View Transitions -->
    <ClientRouter />

    <!-- Theme Script (prevents flash) -->
    <script is:inline>
      (function() {
        const theme = localStorage.getItem('theme');
        if (theme === 'light') {
          document.documentElement.classList.remove('dark');
        } else {
          document.documentElement.classList.add('dark');
        }
      })();
    </script>

    {gaId && (
      <>
        <script type="text/partytown" async src={`https://www.googletagmanager.com/gtag/js?id=${gaId}`}></script>
        <script type="text/partytown" is:inline define:vars={{ gaId }}>
          window.dataLayer = window.dataLayer || [];
          window.gtag = function(){window.dataLayer.push(arguments);}
          window.gtag('js', new Date());
          window.gtag('config', gaId);
        </script>
      </>
    )}
  </head>
  <body>
    <div class="noise-overlay" aria-hidden="true"></div>
    <div id="vibe-toast" class="vibe-toast" role="status" aria-live="polite">BL4Z3 mode unlocked</div>
    <Nav />
    <main transition:animate="none">
      <slot />
    </main>
    <Footer />
    <script>
      import Lenis from 'lenis';

      let lenis;
      let lenisRafId;

      function initSmoothScroll() {
        if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
          initSectionSmoothLinks();
          initVimNavigation();
          return;
        }
        if (lenis) lenis.destroy();
        if (lenisRafId) cancelAnimationFrame(lenisRafId);

        lenis = new Lenis({
          duration: 1.15,
          easing: (t) => Math.min(1, 1.001 - Math.pow(2, -10 * t)),
          smoothWheel: true,
          wheelMultiplier: 0.95,
        });

        function raf(time) {
          lenis?.raf(time);
          lenisRafId = requestAnimationFrame(raf);
        }

        lenisRafId = requestAnimationFrame(raf);
        initSectionSmoothLinks();
        initVimNavigation();
      }

      function getHashTarget(href) {
        const url = new URL(href, window.location.href);
        const isSamePage = url.origin === window.location.origin && url.pathname === window.location.pathname;
        if (!isSamePage || !url.hash) return null;
        return document.getElementById(decodeURIComponent(url.hash.slice(1)));
      }

      function initSectionSmoothLinks() {
        document.querySelectorAll('a[href*="#"]').forEach((link) => {
          if (link.dataset.lenisSectionLink === 'true') return;
          link.dataset.lenisSectionLink = 'true';

          link.addEventListener('click', (event) => {
            const target = getHashTarget(link.href);
            if (!target) return;

            event.preventDefault();
            history.pushState(null, '', `#${target.id}`);

            if (lenis && !window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
              lenis.scrollTo(target, {
                offset: -84,
                duration: 1.15,
                easing: (t) => Math.min(1, 1.001 - Math.pow(2, -10 * t)),
              });
              return;
            }

            target.scrollIntoView({ behavior: 'smooth', block: 'start' });
          });
        });
      }

      function getPageSections() {
        return Array.from(document.querySelectorAll('main section[id]'));
      }

      function getActiveSectionIndex(sections) {
        const anchorY = window.scrollY + 120;
        let activeIndex = 0;

        sections.forEach((section, index) => {
          if (section.offsetTop <= anchorY) {
            activeIndex = index;
          }
        });

        return activeIndex;
      }

      function scrollToSection(section) {
        if (!section) return;
        history.replaceState(null, '', `#${section.id}`);

        if (lenis && !window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
          lenis.scrollTo(section, {
            offset: section.id === 'hero' ? 0 : -84,
            duration: 0.95,
            easing: (t) => Math.min(1, 1.001 - Math.pow(2, -10 * t)),
          });
          return;
        }

        section.scrollIntoView({ behavior: 'smooth', block: 'start' });
      }

      function isTypingTarget(target) {
        if (!(target instanceof HTMLElement)) return false;
        const tagName = target.tagName.toLowerCase();
        return target.isContentEditable || tagName === 'input' || tagName === 'textarea' || tagName === 'select';
      }

      function initVimNavigation() {
        if (document.documentElement.dataset.vimNavigationReady === 'true') return;
        document.documentElement.dataset.vimNavigationReady = 'true';

        let pendingG = false;
        let pendingTimer;

        window.addEventListener('keydown', (event) => {
          if (event.defaultPrevented || event.metaKey || event.ctrlKey || event.altKey || isTypingTarget(event.target)) return;

          const sections = getPageSections();
          if (!sections.length) return;

          const activeIndex = getActiveSectionIndex(sections);
          const key = event.key;

          if (key === 'j') {
            event.preventDefault();
            scrollToSection(sections[Math.min(activeIndex + 1, sections.length - 1)]);
            return;
          }

          if (key === 'k') {
            event.preventDefault();
            scrollToSection(sections[Math.max(activeIndex - 1, 0)]);
            return;
          }

          if (key === 'G') {
            event.preventDefault();
            scrollToSection(sections[sections.length - 1]);
            return;
          }

          if (key === 'g') {
            event.preventDefault();
            if (pendingG) {
              clearTimeout(pendingTimer);
              pendingG = false;
              scrollToSection(sections[0]);
              return;
            }

            pendingG = true;
            pendingTimer = setTimeout(() => {
              pendingG = false;
            }, 650);
          }
        });
      }

      document.addEventListener('astro:page-load', initSmoothScroll);
      document.addEventListener('astro:before-swap', () => {
        lenis?.destroy();
        if (lenisRafId) cancelAnimationFrame(lenisRafId);
      });
    </script>
    <script is:inline>
      function initRevealAnimations() {
        const nodes = document.querySelectorAll('.gsap-fade-up, .gsap-fade-in, .gsap-scale-in');
        if (!nodes.length) return;

        const observer = new IntersectionObserver((entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add('is-visible');
              observer.unobserve(entry.target);
            }
          });
        }, { rootMargin: '0px 0px -12% 0px', threshold: 0.08 });

        nodes.forEach((node, i) => {
          node.style.setProperty('--reveal-delay', `${Math.min(i % 6, 5) * 70}ms`);
          observer.observe(node);
        });
      }

      document.addEventListener('astro:page-load', initRevealAnimations);

      function initMagneticLinks() {
        if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;

        document.querySelectorAll('[data-magnetic]').forEach((node) => {
          node.addEventListener('mousemove', (event) => {
            const rect = node.getBoundingClientRect();
            const x = event.clientX - rect.left - rect.width / 2;
            const y = event.clientY - rect.top - rect.height / 2;
            node.style.transform = `translate(${x * 0.08}px, ${y * 0.12}px)`;
          });

          node.addEventListener('mouseleave', () => {
            node.style.transform = '';
          });
        });
      }

      document.addEventListener('astro:page-load', initMagneticLinks);

      function initEasterEggs() {
        const code = 'bl4z3';
        const logo = document.querySelector('[data-easter-logo]');
        const toast = document.getElementById('vibe-toast');
        let buffer = '';
        let logoClicks = 0;
        let toastTimer;

        function unlock(message) {
          document.documentElement.classList.add('vibe-mode');
          if (toast) {
            toast.textContent = message;
            toast.classList.add('show');
            clearTimeout(toastTimer);
            toastTimer = setTimeout(() => toast.classList.remove('show'), 2400);
          }
        }

        window.addEventListener('keydown', (event) => {
          if (event.metaKey || event.ctrlKey || event.altKey) return;
          buffer = `${buffer}${event.key.toLowerCase()}`.slice(-code.length);
          if (buffer === code) unlock('BL4Z3 mode unlocked');
        });

        logo?.addEventListener('click', () => {
          logoClicks += 1;
          if (logoClicks === 5) {
            unlock('secret handshake accepted');
            logoClicks = 0;
          }
          setTimeout(() => { logoClicks = 0; }, 1200);
        });
      }

      document.addEventListener('astro:page-load', initEasterEggs);
    </script>
  </body>
</html>
