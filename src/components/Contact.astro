---
import { socials } from '../data/experience';

const iconPaths: Record<string, string> = {
  github: 'M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22',
  linkedin: 'M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6zM2 9h4v12H2z M4 2a2 2 0 1 0 0 4 2 2 0 0 0 0-4z',
  instagram: 'M7.8 2h8.4C19.4 2 22 4.6 22 7.8v8.4a5.8 5.8 0 0 1-5.8 5.8H7.8C4.6 22 2 19.4 2 16.2V7.8A5.8 5.8 0 0 1 7.8 2z M16 11.37a4 4 0 1 1-4.73-4.73 4 4 0 0 1 4.73 4.73z M17.5 6.5h.01',
  twitter: 'M4 4l11.733 16H20L8.267 4H4z M4 20l6.768-6.768 M15.232 10.768L20 4',
  spotify: 'M12 2a10 10 0 1 0 0 20 10 10 0 0 0 0-20z M8 15c3-1 6.5-.5 9.5 1.5 M7 12c4-1.5 8-.5 11.5 2 M6.5 9c4.5-1.5 9.5-.5 13 2.5',
};
---

<section id="contact" class="section">
  <div class="container">
    <div class="grid gap-16 md:grid-cols-2 md:items-start md:gap-24">
      <div>
        <div class="section-label gsap-fade-up"><span>03 // Contact</span></div>
        <h2 class="gsap-fade-up mb-6 text-[clamp(2rem,4vw,3rem)] font-bold leading-[1.1] tracking-[-0.03em]">Let's connect<span class="text-[var(--accent)]">.</span></h2>
        <p class="gsap-fade-up mb-8 max-w-[28rem] text-base leading-[1.8] text-[var(--text-secondary)]">
          I'm always open to new opportunities, interesting projects, or just a good conversation.
          Whether you have a question or want to say hi — my inbox is always open.
        </p>

        <a href="mailto:gopalkaul5@gmail.com" class="gsap-fade-up inline-flex items-center gap-3 rounded-xl border border-[var(--border)] bg-[var(--bg-surface)] px-6 py-4 font-mono text-[0.95rem] text-[var(--text)] transition-all duration-300 hover:-translate-y-0.5 hover:border-[var(--accent)] hover:text-[var(--accent)]">
          <span class="flex text-[var(--accent)]">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <rect width="20" height="16" x="2" y="4" rx="2"></rect>
              <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"></path>
            </svg>
          </span>
          gopalkaul5@gmail.com
        </a>
      </div>

      <div class="gsap-fade-up">
        <p class="mb-5 font-mono text-[0.8rem] uppercase tracking-[0.08em] text-[var(--text-muted)]">Find me on</p>
        <div class="flex flex-col gap-2">
          {socials.map((social) => (
            <a
              href={social.url}
              target="_blank"
              rel="noopener noreferrer"
              class="group flex items-center gap-4 rounded-xl border border-[var(--border)] bg-[var(--bg-surface)] px-5 py-4 text-[var(--text-muted)] transition-all duration-300 hover:translate-x-2 hover:border-[var(--accent)] hover:text-[var(--text)]"
              aria-label={`Visit ${social.name}`}
              data-magnetic
            >
              <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="group-hover:text-[var(--accent)]">
                {iconPaths[social.icon]?.split(' M').map((segment, idx) => (
                  <path d={idx === 0 ? segment : `M${segment}`} />
                ))}
              </svg>
              <span class="flex-1 text-sm font-medium">{social.name}</span>
              <svg class="translate-y-1 -translate-x-1 opacity-0 text-[var(--accent)] transition-all duration-300 group-hover:translate-x-0 group-hover:translate-y-0 group-hover:opacity-100" xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <line x1="7" y1="17" x2="17" y2="7"></line>
                <polyline points="7 7 17 7 17 17"></polyline>
              </svg>
            </a>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>
