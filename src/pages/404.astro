---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="404: Not Found — Gopal Kaul">
  <section class="section flex min-h-[80vh] items-center justify-center pt-20 text-center">
    <div class="container">
      <div>
        <div class="gsap-fade-up mb-4 font-mono text-[clamp(5rem,15vw,10rem)] font-extrabold leading-none text-[var(--accent)] opacity-80">404</div>
        <h1 class="section-heading gsap-fade-up">Lost in the grid<span class="text-[var(--accent)]">.</span></h1>
        <p class="gsap-fade-up mx-auto mb-10 max-w-[30rem] text-[1.1rem] text-[var(--text-secondary)]">
          The page you're looking for doesn't exist or has been moved to a different sector.
        </p>
        <div class="gsap-fade-up"><a href="/" class="btn btn-primary">Return to home</a></div>
      </div>
    </div>
  </section>
</BaseLayout>
